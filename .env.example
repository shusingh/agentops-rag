APP_NAME="AgentOps RAG"
APP_VERSION="0.1.0"
ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://agentops:agentops@localhost:5432/agentops_rag
REDIS_URL=redis://localhost:6379/0
OPENSEARCH_URL=http://localhost:9200

JWT_SECRET_KEY=replace-me-with-a-long-random-secret
JWT_ALGORITHM=HS256
DEMO_TOKEN_TTL_MINUTES=60

MODEL_PROVIDER=fake
EMBEDDING_PROVIDER=fake

TRACING_ENABLED=true
TRACING_CONSOLE_EXPORTER=true

RATE_LIMIT_ASK_LIMIT=60
RATE_LIMIT_DOCUMENTS_LIMIT=20
RATE_LIMIT_EVALS_LIMIT=5
RATE_LIMIT_WINDOW_SECONDS=60
